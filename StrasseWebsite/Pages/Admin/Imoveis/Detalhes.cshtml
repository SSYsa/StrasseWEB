@page
@model StrasseWebsite.Pages.DetalhesModel
@{
    ViewData["Title"] = Model.Operacao == "construir" ? "Detalhes do Projeto de Construção" : "Detalhes do Imóvel";
}

<div class="property-details-container">

    <div class="back-to-list">
        <a href="/Listagem?operacao=@Model.Operacao">‹ Voltar para a listagem</a>
    </div>

    <section class="property-gallery">
        <div class="main-photo">
            <img src="@(string.IsNullOrEmpty(Model.Imovel.UrlImagemPrincipal) ? "https://placehold.co/800x450?text=Sem+Foto" : Model.Imovel.UrlImagemPrincipal)" alt="@Model.Imovel.Titulo">
        </div>
        <div class="thumbs-grid">
            @if (Model.Imovel.ImagensSecundarias != null && Model.Imovel.ImagensSecundarias.Any())
            {
                var fotosExibidas = Model.Imovel.ImagensSecundarias.Take(4).ToList();
                var totalFotos = Model.Imovel.ImagensSecundarias.Count;

                for (int i = 0; i < fotosExibidas.Count; i++)
                {
                    if (i == 3 && totalFotos > 4)
                    {
                        <!-- Se houver mais de 4 fotos secundárias, cria a caixa com o contador "+X" -->
                        <div class="more-photos-thumb" style="position: relative; display: block; height: 100%;">
                            <img src="@fotosExibidas[i].UrlImagem" alt="Miniatura @(i + 2)" style="width: 100%; height: 100%; object-fit: cover;">
                            <span class="overlay-count" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 20px;">+@(totalFotos - 3)</span>
                        </div>
                    }
                    else
                    {
                        <img src="@fotosExibidas[i].UrlImagem" alt="Miniatura @(i + 2)">
                    }
                }
            }
            else
            {
                <img src="https://placehold.co/200x135?text=Strasse+1" alt="Miniatura Padrão">
                <img src="https://placehold.co/200x135?text=Strasse+2" alt="Miniatura Padrão">
                <img src="https://placehold.co/200x135?text=Strasse+3" alt="Miniatura Padrão">
            }
        </div>
    </section>

    <div class="details-content-grid">

        <main class="info-column">
            <div class="property-main-header">
                <span class="badge-status">@((Model.Operacao == "construir") ? "Pronto para Construir" : "Exclusividade")</span>
                <h1>@Model.Imovel.Titulo</h1>
                <p class="location-text">📍 @Model.Imovel.Endereco, @Model.Imovel.Bairro - @Model.Imovel.CidadeEstado | Código: <strong class="text-danger">@Model.Imovel.CodigoImovel</strong></p>
            </div>

            <div class="specs-ribbon">
                <div class="spec-item">
                    <span class="spec-icon">📐</span>
                    <span class="spec-value">@Model.Imovel.TamanhoConstruido m²</span>
                    <span class="spec-label">Área Útil</span>
                </div>
                <div class="spec-item">
                    <span class="spec-icon">🛏️</span>
                    <span class="spec-value">@Model.Imovel.QuantidadeQuartos</span>
                    <span class="spec-label">Quartos</span>
                </div>
                <div class="spec-item">
                    <span class="spec-icon">🚿</span>
                    <span class="spec-value">@Model.Imovel.QuantidadeBanheiros</span>
                    <span class="spec-label">Banheiros</span>
                </div>
                <div class="spec-item">
                    <span class="spec-icon">🚗</span>
                    <span class="spec-value">@Model.Imovel.QuantidadeVagasGaragem</span>
                    <span class="spec-label">Vagas</span>
                </div>
            </div>

            <div class="price-details-box">
                <div class="price-row">
                    <span class="price-label">Valor do Investimento</span>
                    <span class="price-value-main">R$ @Model.Imovel.Preco.ToString("N2")</span>
                </div>
                <div class="fees-row">
                    <span><strong>Terreno:</strong> @Model.Imovel.TamanhoTerreno m²</span>
                    <span><strong>Forma de Pagamento:</strong> @Model.Imovel.PagamentoDisponivel.ToString()</span>
                </div>
            </div>

            <div class="description-section">
                <h2>Descrição do Imóvel</h2>
                <p style="white-space: pre-line;">@Model.Imovel.Descricao</p>
            </div>

            <div class="features-section">
                <h2>Características do Imóvel</h2>
                <div class="features-grid">
                    @if (Model.Imovel.TemPiscina)
                    {
                        <div class="feature-tag-item">✓ Churrasqueira / Piscina</div>
                    }
                    @if (Model.Imovel.TemAcademia)
                    {
                        <div class="feature-tag-item">✓ Academia</div>
                    }
                    @if (Model.Imovel.TemGaragem)
                    {
                        <div class="feature-tag-item">✓ Portão Eletrônico / Garagem</div>
                    }
                    @if (Model.Imovel.QuantidadeSalas > 0)
                    {
                        <div class="feature-tag-item">✓ @Model.Imovel.QuantidadeSalas Salas</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Imovel.ConstrutoraResponsavel))
                    {
                        <div class="feature-tag-item">🏗️ @Model.Imovel.ConstrutoraResponsavel</div>
                    }
                    <div class="feature-tag-item">✓ Tipo: @Model.Imovel.Tipo.ToString()</div>
                </div>
            </div>
        </main>

        <aside class="contact-sidebar">
            <div class="sticky-contact-box">
                <h3>@((Model.Operacao == "construir") ? "Gostou? Simule seu Projeto" : "Fale com um Corretor")</h3>
                <p class="sidebar-subtitle">Preencha o formulário abaixo e nossa equipe da Strasse entrará em contato em minutos.</p>

                <form method="post" class="contact-property-form">
                    <div class="form-group">
                        <label for="txtName">Nome Completo</label>
                        <input type="text" id="txtName" name="name" placeholder="Ex: João Silva" required>
                    </div>

                    <div class="form-group">
                        <label for="txtEmail">E-mail</label>
                        <input type="email" id="txtEmail" name="email" placeholder="Ex: joao@email.com" required>
                    </div>

                    <div class="form-group">
                        <label for="txtPhone">Telefone / WhatsApp</label>
                        <input type="tel" id="txtPhone" name="phone" placeholder="(47) 99999-9999" required>
                    </div>

                    <div class="form-group">
                        <label for="txtMessage">Mensagem</label>
                        <textarea id="txtMessage" name="message" rows="4">Olá! Tenho interesse neste imóvel (@Model.Imovel.CodigoImovel) localizado em @Model.Imovel.Bairro. Gostaria de receber mais informações.</textarea>
                    </div>

                    <button type="submit" class="btn-send-lead">
                        @((Model.Operacao == "construir") ? "Quero Construir Meu Sonho" : "Enviar Mensagem")
                    </button>
                </form>

                <div class="direct-whatsapp-box">
                    <span>Ou se preferir, chame agora:</span>
                    <a href="https://wa.me/5547984917838?text=Olá! Tenho interesse no imóvel @Model.Imovel.CodigoImovel que vi no site da Strasse." target="_blank" class="btn-whatsapp-direct">💬 Chame no WhatsApp</a>
                </div>
            </div>
        </aside>

    </div>
</div>