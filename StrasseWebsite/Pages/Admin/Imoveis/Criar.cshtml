@page "/Admin/Imoveis/Criar"
@model StrasseWebsite.Pages.Admin.Imoveis.CriarModel
using StrasseWebsite.Models;
@{
    Layout = "_Layout"; // Ou um layout próprio do painel admin se tiver
    ViewData["Title"] = "Painel - Cadastrar Imóvel";
}

<div class="container my-5">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Novo Imóvel - Painel Administrativo</h4>
            <span class="badge bg-danger">Área Restrita</span>
        </div>
        <div class="card-body">
            
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">1. Informações Básicas</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Imovel.Titulo" class="form-label">Título do Anúncio *</label>
                        <input asp-for="Imovel.Titulo" class="form-control" placeholder="Ex: Sobrado Moderno com Piscina" />
                        <span asp-validation-for="Imovel.Titulo" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Imovel.Transacao" class="form-label">Tipo de Transação</label>
                        <select asp-for="Imovel.Transacao" asp-items="Html.GetEnumSelectList<TipoTransacao>()" class="form-select"></select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Imovel.Tipo" class="form-label">Tipo do Imóvel</label>
                        <select asp-for="Imovel.Tipo" asp-items="Html.GetEnumSelectList<TipoImovel>()" class="form-select"></select>
                    </div>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label asp-for="Imovel.Preco" class="form-label">Preço (R$) *</label>
                        <input asp-for="Imovel.Preco" type="number" step="0.01" class="form-control" />
                        <span asp-validation-for="Imovel.Preco" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Imovel.PagamentoDisponivel" class="form-label">Forma de Pagamento Principal</label>
                        <select asp-for="Imovel.PagamentoDisponivel" asp-items="Html.GetEnumSelectList<FormaPagamento>()" class="form-select"></select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Imovel.Status" class="form-label">Status Inicial</label>
                        <select asp-for="Imovel.Status" class="form-select">
                            <option value="Disponivel">Disponível</option>
                            <option value="Vendido">Vendido</option>
                            <option value="Reservado">Reservado</option>
                        </select>
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">2. Localização</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-5">
                        <label asp-for="Imovel.Endereco" class="form-label">Endereço (Rua, Nº) *</label>
                        <input asp-for="Imovel.Endereco" class="form-control" />
                        <span asp-validation-for="Imovel.Endereco" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Imovel.Bairro" class="form-label">Bairro *</label>
                        <input asp-for="Imovel.Bairro" class="form-control" />
                        <span asp-validation-for="Imovel.Bairro" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Imovel.CidadeEstado" class="form-label">Cidade/Estado *</label>
                        <input asp-for="Imovel.CidadeEstado" class="form-control" placeholder="Blumenau/SC" />
                        <span asp-validation-for="Imovel.CidadeEstado" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">3. Estrutura e Dimensões</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <label asp-for="Imovel.TamanhoTerreno" class="form-label">Área Terreno (m²)</label>
                        <input asp-for="Imovel.TamanhoTerreno" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Imovel.TamanhoConstruido" class="form-label">Área Construída (m²)</label>
                        <input asp-for="Imovel.TamanhoConstruido" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Imovel.QuantidadeQuartos" class="form-label">Quartos</label>
                        <input asp-for="Imovel.QuantidadeQuartos" type="number" class="form-control" min="0" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Imovel.QuantidadeBanheiros" class="form-label">Banheiros</label>
                        <input asp-for="Imovel.QuantidadeBanheiros" type="number" class="form-control" min="0" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Imovel.QuantidadeSalas" class="form-label">Salas</label>
                        <input asp-for="Imovel.QuantidadeSalas" type="number" class="form-control" min="0" />
                    </div>
                </div>

                <div class="row g-3 mb-4 align-items-center">
                    <div class="col-md-3">
                        <div class="form-check form-switch">
                            <input asp-for="Imovel.TemPiscina" class="form-check-input" type="checkbox" />
                            <label asp-for="Imovel.TemPiscina" class="form-check-label">Possui Piscina</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check form-switch">
                            <input asp-for="Imovel.TemAcademia" class="form-check-input" type="checkbox" />
                            <label asp-for="Imovel.TemAcademia" class="form-check-label">Possui Academia</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check form-switch">
                            <input asp-for="Imovel.TemGaragem" class="form-check-input" type="checkbox" />
                            <label asp-for="Imovel.TemGaragem" class="form-check-label">Possui Garagem</label>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="Imovel.QuantidadeVagasGaragem" class="form-label">Vagas de Garagem</label>
                        <input asp-for="Imovel.QuantidadeVagasGaragem" type="number" class="form-control" min="0" />
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">4. Mídia e Detalhes</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-8">
                        <label asp-for="Imovel.UrlImagemPrincipal" class="form-label">URL da Imagem Principal *</label>
                        <input asp-for="Imovel.UrlImagemPrincipal" class="form-control" placeholder="https://exemplo.com/foto.jpg" />
                        <span asp-validation-for="Imovel.UrlImagemPrincipal" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Imovel.ConstrutoraResponsavel" class="form-label">Construtora (Opcional)</label>
                        <input asp-for="Imovel.ConstrutoraResponsavel" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Imovel.Descricao" class="form-label">Descrição Detalhada do Imóvel *</label>
                        <textarea asp-for="Imovel.Descricao" class="form-control" rows="4" placeholder="Escreva sobre os acabamentos, diferenciais..."></textarea>
                        <span asp-validation-for="Imovel.Descricao" class="text-danger"></span>
                    </div>
                </div>

                <h5 class="text-secondary border-bottom pb-2 mb-3">5. Vínculos Administrativos</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Imovel.ProprietarioId" class="form-label">Proprietário Vinculado *</label>
                        <select asp-for="Imovel.ProprietarioId" asp-items="Model.ProprietariosList" class="form-select">
                            <option value="">-- Selecione o Proprietário --</option>
                        </select>
                        <span asp-validation-for="Imovel.ProprietarioId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Imovel.CorretorId" class="form-label">Corretor Responsável *</label>
                        <select asp-for="Imovel.CorretorId" asp-items="Model.CorretoresList" class="form-select">
                            <option value="">-- Selecione o Corretor --</option>
                        </select>
                        <span asp-validation-for="Imovel.CorretorId" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="/Admin/Dashboard" class="btn btn-outline-secondary">Cancelar</a>
                    <button type="submit" class="btn btn-danger px-4" style="background-color: #C00000;">Cadastrar Imóvel no Sistema</button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}